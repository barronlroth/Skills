#!/bin/bash
# Skillfile — portable agent skills setup
# Run: bash Skillfile
#
# Installs all agent skills globally. Each source updates
# independently via `npx skills update`.

set -e

echo "Installing agent skills..."

# Impeccable design pack (17 skills)
npx skills add pbakaus/impeccable --all -g -y

# Vercel agent skills (4 skills)
npx skills add vercel-labs/agent-skills --all -g -y

# Vercel agent browser (5 skills)
npx skills add vercel-labs/agent-browser --all -g -y

# Anthropic (frontend-design, skill-creator)
npx skills add anthropics/skills --skill frontend-design --skill skill-creator -g -y

# Taste skill pack (7 skills)
npx skills add leonxlnx/taste-skill --all -g -y

# App Store Connect CLI skills (21 skills)
npx skills add rudrankriyam/app-store-connect-cli-skills --all -g -y

# dimillian iOS/SwiftUI/macOS pack (14 skills)
npx skills add dimillian/skills --all -g -y

# SwiftUI expert + update APIs (2 skills)
npx skills add avdlee/swiftui-agent-skill --all -g -y

# Swift concurrency (1 skill)
npx skills add avdlee/swift-concurrency-agent-skill -g -y

# Humanizer (1 skill)
npx skills add blader/humanizer -g -y

# Remotion (1 skill)
npx skills add remotion-dev/skills -g -y

# Custom — CXAS (4 skills)
npx skills add barronlroth/Skills --all -g -y

echo "Done. Run 'npx skills check' to verify."
